generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
 // directUrl = env("DATABASE_URL_UNPOOLED")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  plan          Plan      @default(FREE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime  @default(now())

  switchEnabled      Boolean      @default(false)
  switchIntervalDays Int          @default(30)
  switchLastCheckin  DateTime     @default(now())
  switchStatus       SwitchStatus @default(ACTIVE)
  driveFolderId      String?

  accounts   Account[]
  sessions   Session[]
  messages   Message[]
  keyholders Keyholder[]
  switchLogs SwitchLog[]
}

model Message {
  id          String        @id @default(cuid())
  userId      String
  title       String
  content     String        @db.Text
  type        MessageType   @default(TEXT)
  status      MessageStatus @default(DRAFT)
  triggerType TriggerType   @default(SWITCH)
  scheduledAt DateTime?
  driveFileId String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  sentAt      DateTime?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipients Recipient[]

  @@index([userId])
  @@index([status])
  @@index([triggerType])
}

model Recipient {
  id          String          @id @default(cuid())
  messageId   String
  name        String
  email       String?
  phone       String?
  channel     DeliveryChannel @default(EMAIL)
  status      DeliveryStatus  @default(PENDING)
  deliveredAt DateTime?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model Keyholder {
  id              String    @id @default(cuid())
  userId          String
  name            String
  email           String
  activationToken String    @unique @default(cuid())
  confirmedAt     DateTime?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SwitchLog {
  id        String      @id @default(cuid())
  userId    String
  event     SwitchEvent
  details   String?
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  BASIC
  PREMIUM
}

enum SwitchStatus {
  ACTIVE
  WARNING
  CRITICAL
  TRIGGERED
  PAUSED
}

enum MessageType {
  TEXT
  AUDIO
  VIDEO
}

enum MessageStatus {
  DRAFT
  ACTIVE
  SENT
  FAILED
}

enum TriggerType {
  SWITCH
  DATE
  KEYHOLDER
}

enum DeliveryChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum SwitchEvent {
  CHECKIN
  REMINDER_SENT
  WARNING_SENT
  CRITICAL_SENT
  KEYHOLDER_NOTIFIED
  TRIGGERED
  PAUSED
  RESUMED
}
